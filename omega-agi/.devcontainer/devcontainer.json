{
  "name": "ΩMEGA AGI SUPREMACY",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "forwardPorts": [8080],
  "remoteUser": "codespace",
  "containerEnv": {
    "OMEGA_LOG_LEVEL": "info",
    "OMEGA_DATA_DIR": "/workspaces/omega-agi/data",
    "OMEGA_TRANSCENDENCE": "true"
  },
  "postCreateCommand": "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y && source $HOME/.cargo/env && cargo check",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "vadimcn.vscode-lldb",
        "GitHub.copilot",
        "eamodio.gitlens"
      ],
      "settings": {
        "rust-analyzer.checkOnSave.command": "clippy",
        "rust-analyzer.cargo.allFeatures": true,
        "editor.formatOnSave": true,
        "editor.rulers": [100, 120]
      }
    }
  }
}
