# =============================================================================
# ΩMEGA AGI SUPREMACY — 环境配置模板
# =============================================================================
# 复制此文件为 .env 并填入你的密钥
#   cp .env.example .env
# =============================================================================

# ── API Keys ───────────────────────────────────────────────────────
# GitHub 个人访问令牌（用于自我进化代码提交）
# 生成: https://github.com/settings/tokens (需要 repo 权限)
GITHUB_TOKEN=

# OpenAI API Key（用于 Agent 推理）
# 或使用 OMEGA_API_KEY 作为别名
OPENAI_API_KEY=
# OMEGA_API_KEY=

# ── 运行配置 ──────────────────────────────────────────────────────
# 日志级别: trace | debug | info | warn | error
OMEGA_LOG_LEVEL=info

# 数据存储目录（默认 ./data）
OMEGA_DATA_DIR=./data

# 启用元认知层（Layer 10）
# true  | 1  = 启用
# false | 0  = 禁用
OMEGA_TRANSCENDENCE=true

# ── Adapter 连接配置（可选）───────────────────────────────────────
# OpenClaw 协议端点
OPENCLAW_ENDPOINT=http://localhost:8080

# Hermes 协议端点
HERMES_ENDPOINT=http://localhost:9090

# OpenHuman 协议端点
OPENHUMAN_ENDPOINT=http://localhost:7070

# 飞书机器人 Webhook URL
FEISHU_WEBHOOK_URL=

# ── 容器部署配置（可选）───────────────────────────────────────────
# 仅在 Docker 部署时需要
RUST_BACKTRACE=1
