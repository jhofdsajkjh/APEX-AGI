# OMEGA AGI Supremacy - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED - Authentication
# =============================================================================
GITHUB_TOKEN=your_github_token_here

# =============================================================================
# MODE & LOGGING
# =============================================================================
OMEGA_MODE=production          # production | development | staging
LOG_LEVEL=info                 # trace | debug | info | warn | error
RUST_LOG=info                  # Rust log level (same as LOG_LEVEL)

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_SWARM=true
ENABLE_EVOLUTION=true

# =============================================================================
# PORTS (defaults shown)
# =============================================================================
# OMEGA_CORE_PORT=8080
# OMEGA_METRICS_PORT=9090
# OMEGA_MONITOR_PORT=9091
# OMEGA_GRAFANA_PORT=3000

# =============================================================================
# OPTIONAL - Monitoring (enable with: docker-compose --profile monitoring up)
# =============================================================================
GRAFANA_PASSWORD=admin

# =============================================================================
# VOLUME PATHS
# =============================================================================
# DATA_DIR=./data
# CONFIG_DIR=./config
# MODELS_DIR=./models
# =============================================================================
# FEISHU (LARK) INTEGRATION - Optional
# Get these from https://open.feishu.cn/app > Credentials & Basic Info
# =============================================================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_BOT_NAME=OMEGA AGI Bot
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
FEISHU_NOTIFICATION_CHAT_ID=oc_xxxxxxxxxxxxxxxx
FEISHU_ENABLE_GROUP=false

# =============================================================================
# OMEGA AGI - LLM Provider
# =============================================================================
OMEGA_LLM_PROVIDER=manual                 # manual | openai | custom
OMEGA_API_URL=                            # e.g. https://api.openai.com/v1
OMEGA_API_KEY=                            # Your API key (leave empty for mock mode)
OMEGA_MODEL_NAME=gpt-4o                   # Model name (gpt-4o, o1-mini, claude-3, deepseek-chat, ...)
OMEGA_MAX_TOKENS=4096                     # Max tokens per LLM response
OMEGA_TEMPERATURE=0.7                     # LLM temperature (0.0-2.0)
